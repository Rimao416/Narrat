{
  "expo": {
    "name": "narrat-mobile",
    "slug": "narrat-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "narratmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.narrat.app"
    },
    "android": {
      "package": "com.narrat.app"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
