// =============================================================================
// NARRAT — Prisma Schema
// Version: 1.0.0
// Database: PostgreSQL 15+
// ORM: Prisma 5+
//
// Conventions:
//   - IDs: cuid() pour tous les enregistrements publics
//   - Timestamps: createdAt / updatedAt sur toutes les tables
//   - Soft delete: deletedAt nullable sur les entités sensibles
//   - Enums: PascalCase
//   - Relations: explicites avec @relation nommées
//   - Index: sur toutes les foreign keys + colonnes de recherche fréquente
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum Language {
  FR
  EN
  LN // Lingala
  SW // Swahili
}

enum UserRole {
  USER
  MODERATOR
  EDITOR
  ADMIN
  SUPER_ADMIN
}

enum SpiritualLevel {
  NEW_BELIEVER      // < 1 an
  BELIEVER          // 1–5 ans
  ESTABLISHED       // 5 ans+
  LEADER
  PASTOR
}

enum ContentFormat {
  TEXT
  AUDIO
  VIDEO
  TEXT_AUDIO
  TEXT_VIDEO
  ALL
}

enum ContentStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
  REJECTED
}

enum BookCategory {
  THEOLOGY
  BIOGRAPHY
  SPIRITUAL_GROWTH
  PRAYER
  MARRIAGE_FAMILY
  FINANCES
  SPIRITUAL_WARFARE
  APOLOGETICS
  CHURCH_HISTORY
  ESCHATOLOGY
  SENSITIVE_TOPICS
  YOUTH_IDENTITY
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum QuizQuestionType {
  MCQ           // Multiple Choice Question
  TRUE_FALSE
  MATCHING
  FILL_BLANK
}

enum BibleBook {
  // Ancien Testament
  GENESIS EXODUS LEVITICUS NUMBERS DEUTERONOMY
  JOSHUA JUDGES RUTH
  SAMUEL_1 SAMUEL_2 KINGS_1 KINGS_2
  CHRONICLES_1 CHRONICLES_2
  EZRA NEHEMIAH ESTHER
  JOB PSALMS PROVERBS ECCLESIASTES SONG_OF_SOLOMON
  ISAIAH JEREMIAH LAMENTATIONS EZEKIEL DANIEL
  HOSEA JOEL AMOS OBADIAH JONAH MICAH
  NAHUM HABAKKUK ZEPHANIAH HAGGAI ZECHARIAH MALACHI
  // Nouveau Testament
  MATTHEW MARK LUKE JOHN
  ACTS
  ROMANS CORINTHIANS_1 CORINTHIANS_2 GALATIANS EPHESIANS
  PHILIPPIANS COLOSSIANS THESSALONIANS_1 THESSALONIANS_2
  TIMOTHY_1 TIMOTHY_2 TITUS PHILEMON
  HEBREWS JAMES
  PETER_1 PETER_2
  JOHN_1 JOHN_2 JOHN_3 JUDE
  REVELATION
}

enum BibleTranslation {
  LSG   // Louis Segond
  NEG   // Nouvelle Edition de Genève
  BDS   // Bible du Semeur
  NBS   // Nouvelle Bible Segond
  S21   // Segond 21
  NIV
  ESV
  KJV
  NKJV
}

enum ConfessionType {
  CONFESSION
  TESTIMONY
  PRAYER_REQUEST
  SPIRITUAL_QUESTION
  ENCOURAGEMENT
}

enum ConfessionVisibility {
  PUBLIC
  THEMATIC_GROUP
  PRIVATE_GROUP
  ANONYMOUS_PUBLIC
}

enum ChallengeCategory {
  PURITY
  MENTAL_HEALTH
  PRAYER
  BIBLE_READING
  FASTING
  FORGIVENESS
  ANGER
  GRATITUDE
  EVANGELISM
  FAMILY
}

enum ChallengeIntensity {
  LIGHT
  MODERATE
  INTENSE
}

enum ChallengeStatus {
  NOT_STARTED
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

enum PrayerRequestStatus {
  ACTIVE
  ANSWERED
  WAITING
  CLOSED
}

enum PrayerCategory {
  PERSONAL
  FAMILY
  WORK
  HEALTH
  NATION
  CHURCH
  OTHER
}

enum MusicStyle {
  AFRICAN_GOSPEL
  CONTEMPORARY_GOSPEL
  CHARISMATIC_PRAISE
  CLASSICAL_HYMN
  INTIMATE_WORSHIP
  REVIVAL_SONGS
}

enum QuizCategory {
  OLD_TESTAMENT
  NEW_TESTAMENT
  PSALMS
  PROVERBS
  GOSPELS
  EPISTLES
  PROPHETS
  BIBLICAL_GEOGRAPHY
  BIBLICAL_CHARACTERS
  PARABLES
  MIRACLES
  FAMOUS_VERSES
  CHURCH_HISTORY
}

enum QuizDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum TournamentStatus {
  UPCOMING
  ACTIVE
  FINISHED
}

enum NotificationType {
  DAILY_VERSE
  MORNING_THOUGHT
  PRAYER_REMINDER
  ACTION_CALL
  COMMUNITY_REPLY
  CHALLENGE_REMINDER
  QUIZ_CHALLENGE
  SPIRITUAL_HEALTH_REMINDER
  SYSTEM
}

enum RevivalEra {
  NINETEENTH_CENTURY
  EARLY_TWENTIETH
  MID_TWENTIETH
  CONTEMPORARY
}

enum RevivalRegion {
  AFRICA
  AMERICAS
  EUROPE
  ASIA
  WORLDWIDE
}

enum SpiritualHealthDimension {
  WORD
  PRAYER
  COMMUNITY
  INTEGRITY
  GENEROSITY
  GROWTH
}

enum ContactStatus {
  NEVER_HEARD
  REFLECTING
  BELIEVER
  GROWING
}

enum ModerationAction {
  APPROVED
  REJECTED
  WARNING_SENT
  USER_BLOCKED
  ESCALATED
}

enum ModerationReason {
  INAPPROPRIATE
  HERESY
  SPAM
  HARMFUL_CONTENT
  IMMINENT_DANGER
  FALSE_INFORMATION
}

enum BadgeCategory {
  WELCOME
  REGULARITY
  MODULE
  CHALLENGE
  QUIZ
  COMMUNITY
  SPECIAL
}

// =============================================================================
// CORE — USER & AUTH
// =============================================================================

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  emailVerified     Boolean        @default(false)
  emailVerifiedAt   DateTime?
  passwordHash      String?
  // OAuth
  googleId          String?        @unique
  appleId           String?        @unique
  // Profile
  firstName         String
  lastName          String?
  username          String?        @unique
  avatarUrl         String?
  bio               String?        @db.VarChar(150)
  city              String?
  country           String?        @db.Char(2) // ISO 3166-1 alpha-2
  localChurch       String?
  // Spiritual profile
  spiritualLevel    SpiritualLevel @default(NEW_BELIEVER)
  language          Language       @default(FR)
  // App state
  role              UserRole       @default(USER)
  isActive          Boolean        @default(true)
  isBanned          Boolean        @default(false)
  bannedAt          DateTime?
  bannedReason      String?
  lastSeenAt        DateTime?
  // Privacy
  isProfilePublic   Boolean        @default(true)
  allowDirectChat   Boolean        @default(true)
  // XP & Gamification
  xpTotal           Int            @default(0)
  quizLevel         QuizDifficulty @default(BEGINNER)
  // Timestamps
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?

  // Relations
  sessions              UserSession[]
  refreshTokens         RefreshToken[]
  interests             UserInterest[]
  readingProgress       ReadingProgress[]
  bookmarks             Bookmark[]
  annotations           Annotation[]
  bookLists             BookList[]
  downloadedContent     DownloadedContent[]
  courseEnrollments     CourseEnrollment[]
  quizSessions          QuizSession[]
  quizDuels             QuizDuel[]            @relation("QuizDuelChallenger")
  quizDuelsReceived     QuizDuel[]            @relation("QuizDuelOpponent")
  tournamentEntries     TournamentEntry[]
  userBadges            UserBadge[]
  confessions           Confession[]
  confessionReplies     ConfessionReply[]
  prayerCounts          PrayerCount[]
  groupMemberships      GroupMembership[]
  privateGroupsCreated  CommunityGroup[]      @relation("GroupCreator")
  directChatsInitiated  DirectChat[]          @relation("DirectChatInitiator")
  directChatsReceived   DirectChat[]          @relation("DirectChatReceiver")
  directMessages        DirectMessage[]
  prayerRequests        PrayerRequest[]
  prayerJournalEntries  PrayerJournalEntry[]
  intercessionPrayers   IntercessionPrayer[]
  challenges            UserChallenge[]
  challengePartnerOf    ChallengePartner[]    @relation("ChallengePartner")
  challengePartnerFor   ChallengePartner[]    @relation("ChallengePartnerFor")
  dailyCheckIns         DailyCheckIn[]
  songFavorites         SongFavorite[]
  playlists             Playlist[]
  contacts              EvangelismContact[]
  spiritualHealthLogs   SpiritualHealthLog[]
  growthPlans           GrowthPlan[]
  notificationSettings  NotificationSetting[]
  notifications         Notification[]
  savedVerses           SavedVerse[]
  moderationActions     ModerationLog[]       @relation("ModeratorActions")
  reportsSubmitted      Report[]              @relation("ReportSubmitter")
  flaggedContent        Report[]              @relation("ReportedUser")
  aiConversations       AIConversation[]

  @@index([email])
  @@index([username])
  @@index([googleId])
  @@index([appleId])
  @@index([deletedAt])
  @@map("users")
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  deviceInfo   String?
  ipAddress    String?
  userAgent    String?
  isActive     Boolean  @default(true)
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model UserInterest {
  id       String       @id @default(cuid())
  userId   String
  category BookCategory

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@map("user_interests")
}

// =============================================================================
// MODULE 01 — BIBLIOTHÈQUE CHRÉTIENNE
// =============================================================================

model Author {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  bio         String?  @db.Text
  nationality String?  @db.Char(2)
  birthYear   Int?
  deathYear   Int?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  books   Book[]
  revival RevivalFigure?

  @@map("authors")
}

model Book {
  id                String        @id @default(cuid())
  slug              String        @unique
  title             String
  subtitle          String?
  authorId          String
  publisher         String?
  publishYear       Int?
  language          Language      @default(FR)
  category          BookCategory
  coverUrl          String?
  description       String        @db.Text
  tableOfContents   Json?         // [{title, chapterIndex, wordCount}]
  estimatedReadTime Int?          // minutes
  audioUrl          String?       // URL du fichier audio complet
  audioDuration     Int?          // secondes
  hasAudio          Boolean       @default(false)
  hasOffline        Boolean       @default(true)
  isSensitive       Boolean       @default(false)
  status            ContentStatus @default(DRAFT)
  viewCount         Int           @default(0)
  downloadCount     Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  author            Author              @relation(fields: [authorId], references: [id])
  chapters          BookChapter[]
  tags              BookTag[]
  verseLinks        BookVerseLink[]
  readingProgress   ReadingProgress[]
  bookmarks         Bookmark[]
  annotations       Annotation[]
  bookListItems     BookListItem[]
  downloadedContent DownloadedContent[]
  recommendations   BookRecommendation[]
  courseLinks       CourseBookLink[]

  @@index([slug])
  @@index([authorId])
  @@index([category])
  @@index([language])
  @@index([status])
  @@index([deletedAt])
  @@map("books")
}

model BookChapter {
  id            String   @id @default(cuid())
  bookId        String
  chapterIndex  Int
  title         String
  content       String   @db.Text
  wordCount     Int      @default(0)
  audioUrl      String?
  audioDuration Int?     // secondes
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  book        Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  bookmarks   Bookmark[]
  annotations Annotation[]

  @@unique([bookId, chapterIndex])
  @@index([bookId])
  @@map("book_chapters")
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  slug  String    @unique
  color String?   @db.VarChar(7) // hex

  books    BookTag[]
  courses  CourseTag[]

  @@map("tags")
}

model BookTag {
  bookId String
  tagId  String

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([bookId, tagId])
  @@map("book_tags")
}

model BookVerseLink {
  id       String      @id @default(cuid())
  bookId   String
  book     BibleBook
  chapter  Int
  verseStart Int
  verseEnd   Int?

  bookRel Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@map("book_verse_links")
}

model ReadingProgress {
  id              String   @id @default(cuid())
  userId          String
  bookId          String
  currentChapter  Int      @default(0)
  currentPosition Int      @default(0) // caractère dans le chapitre
  progressPercent Float    @default(0)
  isCompleted     Boolean  @default(false)
  completedAt     DateTime?
  lastReadAt      DateTime @default(now())
  totalReadTime   Int      @default(0) // secondes
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
  @@index([bookId])
  @@map("reading_progress")
}

model Bookmark {
  id           String   @id @default(cuid())
  userId       String
  bookId       String
  chapterId    String?
  position     Int      @default(0)
  label        String?  @db.VarChar(100)
  createdAt    DateTime @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  book    Book         @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter BookChapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([bookId])
  @@map("bookmarks")
}

model Annotation {
  id           String   @id @default(cuid())
  userId       String
  bookId       String
  chapterId    String?
  startOffset  Int
  endOffset    Int
  highlightColor String @db.VarChar(7) @default("#FFD700")
  note         String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  book    Book         @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter BookChapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([bookId])
  @@map("annotations")
}

model BookList {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items BookListItem[]

  @@index([userId])
  @@map("book_lists")
}

model BookListItem {
  id         String   @id @default(cuid())
  bookListId String
  bookId     String
  addedAt    DateTime @default(now())
  sortOrder  Int      @default(0)

  bookList BookList @relation(fields: [bookListId], references: [id], onDelete: Cascade)
  book     Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookListId, bookId])
  @@index([bookListId])
  @@map("book_list_items")
}

model DownloadedContent {
  id          String   @id @default(cuid())
  userId      String
  bookId      String
  sizeBytes   Int
  downloadedAt DateTime @default(now())
  expiresAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
  @@map("downloaded_content")
}

model BookRecommendation {
  id         String   @id @default(cuid())
  bookId     String
  relatedId  String
  score      Float    @default(0)
  reason     String?
  updatedAt  DateTime @updatedAt

  book    Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, relatedId])
  @@index([bookId])
  @@map("book_recommendations")
}

// Bible History sub-feature
model BibleCharacter {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  era         String
  bibleBook   BibleBook
  chapter     Int?
  description String    @db.Text
  imageUrl    String?
  verseRef    String?
  language    Language  @default(FR)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@map("bible_characters")
}

model BibleMap {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  era         String
  imageUrl    String
  description String?  @db.Text
  language    Language @default(FR)
  createdAt   DateTime @default(now())

  pointsOfInterest BibleMapPoint[]

  @@map("bible_maps")
}

model BibleMapPoint {
  id          String   @id @default(cuid())
  mapId       String
  name        String
  lat         Float
  lng         Float
  description String?  @db.Text
  verseRef    String?

  map BibleMap @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@index([mapId])
  @@map("bible_map_points")
}

model BibleTimeline {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  era         String
  yearStart   Int?      // négatif pour avant JC
  yearEnd     Int?
  description String    @db.Text
  verseRef    String?
  imageUrl    String?
  language    Language  @default(FR)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([slug])
  @@map("bible_timeline")
}

// =============================================================================
// MODULE 02 — CONFESSION & COMMUNAUTÉ
// =============================================================================

model Confession {
  id              String               @id @default(cuid())
  userId          String
  isAnonymous     Boolean              @default(false)
  type            ConfessionType
  visibility      ConfessionVisibility @default(PUBLIC)
  groupId         String?
  content         String               @db.Text @db.VarChar(1500)
  verseRef        String?
  tags            String[]
  prayerCount     Int                  @default(0)
  replyCount      Int                  @default(0)
  isActive        Boolean              @default(true)
  expiresAt       DateTime?
  hasCrisisFlag   Boolean              @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  group          CommunityGroup?    @relation(fields: [groupId], references: [id], onDelete: SetNull)
  replies        ConfessionReply[]
  prayerCounts   PrayerCount[]
  reports        Report[]           @relation("ConfessionReports")
  moderationLogs ModerationLog[]    @relation("ConfessionModerations")

  @@index([userId])
  @@index([type])
  @@index([visibility])
  @@index([groupId])
  @@index([isActive])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("confessions")
}

model ConfessionReply {
  id            String   @id @default(cuid())
  confessionId  String
  userId        String
  isAnonymous   Boolean  @default(false)
  content       String   @db.VarChar(300)
  verseRef      String?
  isHelpful     Boolean  @default(false) // marqué par l'auteur de la confession
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  confession Confession @relation(fields: [confessionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports    Report[]   @relation("ReplyReports")

  @@index([confessionId])
  @@index([userId])
  @@index([deletedAt])
  @@map("confession_replies")
}

model PrayerCount {
  id           String   @id @default(cuid())
  userId       String
  confessionId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  confession Confession @relation(fields: [confessionId], references: [id], onDelete: Cascade)

  @@unique([userId, confessionId])
  @@index([confessionId])
  @@map("prayer_counts")
}

model CommunityGroup {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  rules       String?  @db.Text
  isPublic    Boolean  @default(true)
  isThematic  Boolean  @default(false) // true = groupe pré-défini Narrat
  theme       String?
  creatorId   String
  maxMembers  Int      @default(200)
  memberCount Int      @default(0)
  imageUrl    String?
  inviteCode  String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  creator     User              @relation("GroupCreator", fields: [creatorId], references: [id])
  memberships GroupMembership[]
  confessions Confession[]

  @@index([slug])
  @@index([isPublic])
  @@index([isThematic])
  @@index([inviteCode])
  @@map("community_groups")
}

model GroupMembership {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  isModerator Boolean @default(false)
  isAdmin  Boolean  @default(false)
  joinedAt DateTime @default(now())
  leftAt   DateTime?

  group CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("group_memberships")
}

model DirectChat {
  id            String   @id @default(cuid())
  initiatorId   String
  receiverId    String
  isInitiatorAnon Boolean @default(false)
  isReceiverAnon  Boolean @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  expiresAt     DateTime // 30 jours après création

  initiator User           @relation("DirectChatInitiator", fields: [initiatorId], references: [id])
  receiver  User           @relation("DirectChatReceiver", fields: [receiverId], references: [id])
  messages  DirectMessage[]

  @@index([initiatorId])
  @@index([receiverId])
  @@map("direct_chats")
}

model DirectMessage {
  id         String   @id @default(cuid())
  chatId     String
  senderId   String
  content    String   @db.VarChar(200)
  readAt     DateTime?
  createdAt  DateTime @default(now())
  deletedAt  DateTime?

  chat   DirectChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User       @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([senderId])
  @@map("direct_messages")
}

// Modération
model Report {
  id              String           @id @default(cuid())
  submitterId     String
  reportedUserId  String?
  confessionId    String?
  replyId         String?
  reason          ModerationReason
  description     String?          @db.VarChar(500)
  isResolved      Boolean          @default(false)
  isCrisis        Boolean          @default(false)
  createdAt       DateTime         @default(now())

  submitter      User              @relation("ReportSubmitter", fields: [submitterId], references: [id])
  reportedUser   User?             @relation("ReportedUser", fields: [reportedUserId], references: [id])
  confession     Confession?       @relation("ConfessionReports", fields: [confessionId], references: [id])
  reply          ConfessionReply?  @relation("ReplyReports", fields: [replyId], references: [id])
  moderationLogs ModerationLog[]

  @@index([submitterId])
  @@index([isResolved])
