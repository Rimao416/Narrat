// =============================================================================
// MODULE 03 — ENSEIGNEMENT & FORMATION
// =============================================================================

model Course {
  id               String        @id @default(cuid())
  slug             String        @unique
  title            String
  subtitle         String?
  description      String        @db.Text
  objectives       String[]
  teacherId        String?       // peut être un auteur externe
  teacherName      String?       // si pas dans la DB
  teacherBio       String?       @db.Text
  level            CourseLevel
  language         Language      @default(FR)
  coverUrl         String?
  totalDuration    Int?          // minutes
  moduleCount      Int           @default(0)
  hasCertificate   Boolean       @default(true)
  hasAudio         Boolean       @default(false)
  hasVideo         Boolean       @default(false)
  status           ContentStatus @default(DRAFT)
  enrollCount      Int           @default(0)
  completionRate   Float         @default(0)
  passingScore     Int           @default(70) // %
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  modules     CourseModule[]
  tags        CourseTag[]
  enrollments CourseEnrollment[]
  bookLinks   CourseBookLink[]

  @@index([slug])
  @@index([level])
  @@index([language])
  @@index([status])
  @@map("courses")
}

model CourseTag {
  courseId String
  tagId    String

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([courseId, tagId])
  @@map("course_tags")
}

model CourseBookLink {
  courseId String
  bookId   String

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@id([courseId, bookId])
  @@map("course_book_links")
}

model CourseModule {
  id            String   @id @default(cuid())
  courseId      String
  moduleIndex   Int
  title         String
  content       String   @db.Text
  summary       String?  @db.Text
  audioUrl      String?
  audioDuration Int?
  videoUrl      String?
  videoDuration Int?
  readTime      Int?     // minutes
  verseRefs     String[]
  quotes        Json[]   // [{text, author}]
  isLocked      Boolean  @default(true) // déverrouillé après complétion du précédent
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  quiz        CourseQuiz?
  completions ModuleCompletion[]

  @@unique([courseId, moduleIndex])
  @@index([courseId])
  @@map("course_modules")
}

model CourseQuiz {
  id              String   @id @default(cuid())
  moduleId        String   @unique
  passingScore    Int      @default(70)
  maxAttempts     Int      @default(0) // 0 = illimité
  shuffleQuestions Boolean @default(true)
  createdAt       DateTime @default(now())

  module    CourseModule   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@map("course_quizzes")
}

model QuizQuestion {
  id            String           @id @default(cuid())
  quizId        String?          // null si question du Quiz Biblique global
  biblicalQuizId String?
  type          QuizQuestionType
  question      String           @db.Text
  explanation   String?          @db.Text
  verseRef      String?
  sortOrder     Int              @default(0)
  createdAt     DateTime         @default(now())

  courseQuiz    CourseQuiz?         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  biblicalQuiz  BiblicalQuizBank?   @relation(fields: [biblicalQuizId], references: [id])
  answers       QuizAnswer[]
  attemptItems  QuizAttemptItem[]

  @@index([quizId])
  @@index([biblicalQuizId])
  @@map("quiz_questions")
}

model QuizAnswer {
  id         String  @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean @default(false)
  sortOrder  Int     @default(0)

  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("quiz_answers")
}

model QuizAttempt {
  id          String    @id @default(cuid())
  quizId      String
  userId      String
  score       Int       // 0-100
  isPassed    Boolean   @default(false)
  completedAt DateTime?
  duration    Int?      // secondes
  createdAt   DateTime  @default(now())

  quiz  CourseQuiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  items QuizAttemptItem[]

  @@index([quizId])
  @@index([userId])
  @@map("quiz_attempts")
}

model QuizAttemptItem {
  id           String  @id @default(cuid())
  attemptId    String
  questionId   String
  answerId     String?
  isCorrect    Boolean @default(false)
  timeSpent    Int?    // secondes

  attempt  QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question QuizQuestion @relation(fields: [questionId], references: [id])

  @@index([attemptId])
  @@map("quiz_attempt_items")
}

model CourseEnrollment {
  id                String    @id @default(cuid())
  userId            String
  courseId          String
  progressPercent   Float     @default(0)
  isCompleted       Boolean   @default(false)
  completedAt       DateTime?
  certificateUrl    String?
  certificateIssuedAt DateTime?
  enrolledAt        DateTime  @default(now())
  lastActivityAt    DateTime  @default(now())

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  course           Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  moduleCompletions ModuleCompletion[]

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("course_enrollments")
}

model ModuleCompletion {
  id           String   @id @default(cuid())
  enrollmentId String
  moduleId     String
  quizScore    Int?
  completedAt  DateTime @default(now())
  readTime     Int?     // secondes passés à lire

  enrollment CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  module     CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, moduleId])
  @@index([enrollmentId])
  @@map("module_completions")
}

