  sortOrder    Int @default(0)

  tournament Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@id([tournamentId, questionId])
  @@map("tournament_questions")
}

model TournamentEntry {
  id           String    @id @default(cuid())
  tournamentId String
  userId       String
  score        Int       @default(0)
  rank         Int?
  xpEarned     Int       @default(0)
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([score])
  @@map("tournament_entries")
}

// =============================================================================
// MODULE 10 — FAMILLE CHRÉTIENNE
// =============================================================================

model FamilyGroup {
  id          String   @id @default(cuid())
  name        String
  imageUrl    String?
  inviteCode  String   @unique
  maxMembers  Int      @default(20)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members         FamilyMember[]
  devotionPlans   FamilyDevotionPlan[]
  sharedPrayers   FamilySharedPrayer[]

  @@map("family_groups")
}

model FamilyMember {
  id          String   @id @default(cuid())
  groupId     String
  userId      String
  isAdmin     Boolean  @default(false)
  joinedAt    DateTime @default(now())

  group FamilyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@map("family_members")
}

model DevotionPlan {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  description String?       @db.Text
  audience    String        // COUPLE / FAMILY_YOUNG / FAMILY_TEEN / FAMILY_ADULT
  durationDays Int
  theme       String?
  language    Language      @default(FR)
  status      ContentStatus @default(DRAFT)
  createdAt   DateTime      @default(now())

  days            DevotionDay[]
  familyPlans     FamilyDevotionPlan[]

  @@index([slug])
  @@map("devotion_plans")
}

model DevotionDay {
  id              String   @id @default(cuid())
  planId          String
  dayNumber       Int
  biblePassage    String   // ex: "Jean 3:16-21"
  bibleText       String?  @db.Text
  discussionQ     String   @db.Text
  kidsDiscussionQ String?  @db.Text
  activity        String   @db.Text
  guidedPrayer    String   @db.Text
  createdAt       DateTime @default(now())

  plan       DevotionPlan           @relation(fields: [planId], references: [id], onDelete: Cascade)
  attendance DevotionAttendance[]

  @@unique([planId, dayNumber])
  @@index([planId])
  @@map("devotion_days")
}

model FamilyDevotionPlan {
  id          String    @id @default(cuid())
  groupId     String
  planId      String
  activatedById String
  currentDay  Int       @default(0)
  isActive    Boolean   @default(true)
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  group FamilyGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  plan  DevotionPlan @relation(fields: [planId], references: [id])
  attendances DevotionAttendance[]

  @@index([groupId])
  @@map("family_devotion_plans")
}

model DevotionAttendance {
  id           String   @id @default(cuid())
  planInstanceId String
  dayId        String
  userId       String
  attendedAt   DateTime @default(now())

  planInstance FamilyDevotionPlan @relation(fields: [planInstanceId], references: [id], onDelete: Cascade)
  day          DevotionDay        @relation(fields: [dayId], references: [id])

  @@unique([planInstanceId, dayId, userId])
  @@index([planInstanceId])
  @@map("devotion_attendances")
}

model FamilySharedPrayer {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  title     String
  content   String   @db.Text
  isAnswered Boolean @default(false)
  createdAt DateTime @default(now())

  group FamilyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@map("family_shared_prayers")
}

// =============================================================================
// MODULE 11 — ÉVANGÉLISATION
// =============================================================================

model EvangelismContact {
  id            String        @id @default(cuid())
  userId        String
  firstName     String
  relationship  String        // ami, collègue, famille, voisin, autre
  status        ContactStatus @default(NEVER_HEARD)
  notes         String?       @db.Text
  lastContactAt DateTime?
  prayedForAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  user          User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations EvangelismConversation[]

  @@index([userId])
  @@index([deletedAt])
  @@map("evangelism_contacts")
}

model EvangelismConversation {
  id        String   @id @default(cuid())
  contactId String
  notes     String   @db.Text
  reaction  String?
  nextSteps String?  @db.Text
  loggedAt  DateTime @default(now())

  contact EvangelismContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@map("evangelism_conversations")
}

model Objection {
  id               String   @id @default(cuid())
  slug             String   @unique
  title            String
  shortAnswer      String   @db.Text
  longAnswer       String   @db.Text
  anecdote         String?  @db.Text
  verseRefs        String[]
  keywords         String[]
  language         Language @default(FR)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([slug])
  @@index([language])
  @@map("objections")
}

model SharableResource {
  id          String   @id @default(cuid())
  title       String
  type        String   // IMAGE / VIDEO / TEXT
  imageUrl    String?
  videoUrl    String?
  textContent String?  @db.Text
  theme       String?
  language    Language @default(FR)
  shareCount  Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([language])
  @@map("sharable_resources")
}

// =============================================================================
// MODULE 12 — SANTÉ SPIRITUELLE
// =============================================================================

model SpiritualHealthLog {
  id             String    @id @default(cuid())
  userId         String
  scores         Json      // {WORD: 72, PRAYER: 45, COMMUNITY: 80, INTEGRITY: 60, GENEROSITY: 55, GROWTH: 70}
  globalScore    Float
  openAnswer     String?   @db.Text
  completedAt    DateTime  @default(now())

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  growthPlan GrowthPlan?

  @@index([userId])
  @@index([completedAt])
  @@map("spiritual_health_logs")
}

model GrowthPlan {
  id            String   @id @default(cuid())
  userId        String
  healthLogId   String   @unique
  weakDimensions String[] // les 2 dimensions les plus faibles
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  healthLog SpiritualHealthLog @relation(fields: [healthLogId], references: [id])
  items     GrowthPlanItem[]

  @@index([userId])
  @@map("growth_plans")
}

model GrowthPlanItem {
  id          String  @id @default(cuid())
  planId      String
  dimension   SpiritualHealthDimension
  resourceType String // BOOK / COURSE / CHALLENGE / PRAYER_GUIDE
  resourceId  String
  isAccepted  Boolean @default(false)
  isCompleted Boolean @default(false)
  completedAt DateTime?

  plan GrowthPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@map("growth_plan_items")
}

// =============================================================================
// MODULE 13 — ASSISTANT IA SPIRITUEL
// =============================================================================

model AIConversation {
  id          String   @id @default(cuid())
  userId      String
  sessionId   String   @unique @default(cuid())
  title       String?  // généré automatiquement depuis le 1er message
  isSaved     Boolean  @default(false)
  messageCount Int     @default(0)
  hasCrisisFlag Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expiresAt   DateTime?

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AIMessage[]

  @@index([userId])
  @@index([sessionId])
  @@map("ai_conversations")
}

model AIMessage {
  id              String   @id @default(cuid())
  conversationId  String
  role            String   // user | assistant
  content         String   @db.Text
  verseRefs       String[]
  suggestedModules String[]
  tokenCount      Int?
  hasCrisisFlag   Boolean  @default(false)
  createdAt       DateTime @default(now())

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("ai_messages")
}

model AIPromptTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  systemPrompt String  @db.Text
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ai_prompt_templates")
}

// =============================================================================
// GAMIFICATION — BADGES
// =============================================================================

model Badge {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  description String
  imageUrl    String
  category    BadgeCategory
  condition   Json          // {type, threshold, moduleId?}
  xpReward    Int           @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())

  userBadges UserBadge[]

  @@index([slug])
  @@index([category])
  @@map("badges")
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

// =============================================================================
// ANALYTICS & AUDIT (read-only append tables)
// =============================================================================

model AppEvent {
  id         String   @id @default(cuid())
  userId     String?
  sessionId  String?
  eventName  String
  properties Json?
  deviceInfo String?
  appVersion String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([eventName])
  @@index([createdAt])
  @@map("app_events")
}

model ContentView {
  id          String   @id @default(cuid())
  userId      String?
  contentType String   // book | course | revival | song | etc.
  contentId   String
  duration    Int?     // secondes passés sur le contenu
  createdAt   DateTime @default(now())

  @@index([contentType, contentId])
  @@index([userId])
  @@index([createdAt])
  @@map("content_views")
}

// =============================================================================
// SYSTEM — CMS & CONFIG
// =============================================================================

model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  isPublic  Boolean  @default(false) // si true, exposé via l'API publique
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("app_config")
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  isEnabled   Boolean  @default(false)
  rolloutPct  Int      @default(0) // 0-100
  description String?
  updatedAt   DateTime @updatedAt

  @@map("feature_flags")
}
